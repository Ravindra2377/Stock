# Expo public env vars are exposed to the client app.
# Set this to your backend base URL for local/dev usage.
# Example for physical device on same Wi-Fi:
# EXPO_PUBLIC_API_URL=http://192.168.1.18:8000
# Example for web:
# EXPO_PUBLIC_API_URL=http://localhost:8000

EXPO_PUBLIC_API_URL=http://localhost:8000
